# Shared Telegram application credentials, from https://my.telegram.org/apps.
# Every linked account authenticates through this same app.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# HTTP server (optional, these are the defaults)
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_PATH=/mcp

# Externally reachable base URL. Used as the OAuth issuer/audience and to
# build the /login link, so it must match how MCP clients actually reach
# this server (e.g. behind a reverse proxy or gateway, use that public URL).
MCP_BASE_URL=http://127.0.0.1:8000

# Postgres connection (async SQLAlchemy URL). With docker-compose this is
# overridden to point at the bundled postgres service.
MCP_DB_URL=postgresql+asyncpg://tgmcp:tgmcp@localhost/tgmcp

# High-entropy secret used to sign OAuth access/refresh tokens.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_OAUTH_JWT_SECRET=

# Fernet key used to encrypt linked Telegram sessions at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MCP_SESSION_ENCRYPTION_KEY=
